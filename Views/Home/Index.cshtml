@{
    ViewData["Title"] = "Home Page";
}

<div id="templatemo_content">
    <div id="templatemo_content_left">
        <h1>Welcome to Our .NET Flower site</h1>
        <p>This is a migrated .NET MVC project using the Flower Shop template.</p>
        <p>Aliquam tristique lacus in sapien. Suspendisse potenti. Ut sed pede. Nullam vitae tellus. Sed ultrices. Lorem ipsum dolor sit amet, consectetuer adipiscing elit.</p>
                    
        <div class="cleaner_with_height">&nbsp;</div>
         
        <h2>New Products</h2>
        <div class="product_box">
            <h3>Red Rose Bouquet</h3>
            <img src="~/images/templatemo_image_01.jpg" alt="Red Rose Bouquet" />
            <p>A stunning arrangement of 12 fresh red roses, perfect for any romantic occasion.</p>
            <div class="price">PRICE:<span>$24.99</span></div>
            <div class="buynow"><a href="/Home/Shop">Buy Now</a></div><a href="/Home/Shop">Details</a>
        </div>
        <div class="product_box">
            <h3>Sunflower Mix</h3>
            <img src="~/images/templatemo_image_02.jpg" alt="Sunflower Mix" />
            <p>Bright and cheerful sunflower mix to brighten up any room or event.</p>
            <div class="price">PRICE:<span>$19.99</span></div>
            <div class="buynow"><a href="/Home/Shop">Buy Now</a></div><a href="/Home/Shop">Details</a>
        </div>
        <div class="product_box">
            <h3>Lily & Orchid Combo</h3>
            <img src="~/images/templatemo_image_03.jpg" alt="Lily & Orchid Combo" />
            <p>Elegant combination of white lilies and purple orchids for a luxurious gift.</p>
            <div class="price">PRICE:<span>$34.99</span></div>
            <div class="buynow"><a href="/Home/Shop">Buy Now</a></div><a href="/Home/Shop">Details</a>
        </div>
         
        <div class="cleaner_with_height">&nbsp;</div>
    </div> <!-- end of content left -->
    
    <div id="templatemo_content_right">
        <div class="templatemo_right_section">
            <h4>Search</h4>
            <div class="templatemo_right_section_content">
                <form method="get" action="#">
                        <input name="keyword" type="text" id="keyword"/>
                        <input type="submit" name="submit" class="button" value="Search" />
                 </form>
             </div>
        </div>
        
        <div class="templatemo_right_section">
            <h4>Categories</h4>
            <div class="templatemo_right_section_content">
                <ul>
                    <li><a href="#">Artificial and Silk</a></li>
                    <li><a href="#">Dried and Preserved</a></li>
                    <li><a href="#">Floral</a></li>
                    <li><a href="#">Fresh Cut</a></li>
                    <li><a href="#">Gardens</a></li>
                    <li><a href="#">Gifts</a></li>
                    <li><a href="#">Nurseries</a></li>
                    <li><a href="#">Services</a></li>
                    <li><a href="#">Weddings</a></li>
                    <li><a href="#">Wholesale</a></li>
                </ul>
            </div>
        </div>
    </div> <!-- end of content right-->
    <div class="cleaner">&nbsp;</div>
</div>
