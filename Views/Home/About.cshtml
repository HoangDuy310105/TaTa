@{
    ViewData["Title"] = "About Us";
}

<div id="templatemo_content">
    <div id="templatemo_content_left">
        <h1>About Our Flower Shop</h1>
        <p>@ViewData["Description"]</p>
        <p>@ViewData["Founded"]</p>
        <p>@ViewData["Mission"]</p>

        <div class="cleaner_with_height">&nbsp;</div>

        <h2>Why Choose Us?</h2>
        <ul>
            <li>Fresh flowers sourced daily from local and international growers</li>
            <li>Expert floral designers with over 15 years of experience</li>
            <li>Same-day delivery available for orders placed before 12pm</li>
            <li>Custom arrangements for weddings, events, and corporate orders</li>
            <li>Satisfaction guaranteed on every order</li>
        </ul>

        <div class="cleaner_with_height">&nbsp;</div>
    </div>
    <div class="cleaner">&nbsp;</div>
</div>
